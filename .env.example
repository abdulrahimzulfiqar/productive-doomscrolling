# OpenAI API Key (Fallback for Transcription)
OPENAI_API_KEY=your_openai_api_key_here

# Groq API Key (Primary for Transcription - Fast & Free)
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (For Segmentation)
GEMINI_API_KEY=your_gemini_api_key_here

# YouTube API Key
YOUTUBE_API_KEY=your_official_google_api_key_here

# Webshare Proxies (Recommended for Cloud Hosting)
WEBSHARE_USERNAME=your_webshare_username_here
WEBSHARE_PASSWORD=your_webshare_password_here

# Environment
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
